---
import PageLayout from '../layouts/PageLayout.astro';
import CallbackForm from '../components/CallbackForm.astro';
import Motif from '../components/Motif.astro';
import { site } from '../data/site.js';
---

<PageLayout
  title="Contact | Engage Electrics · Albury Wodonga Electricians"
  description="Call Engage Electrics on (02) 6021 1510 or request a callback. Servicing Albury-Wodonga, NE Victoria and Southern NSW."
  heading="Let's get your electrical sorted"
  sub="Call us, book online or request a callback. Friendly, prompt and reliable across the Border."
  crumb="Contact"
  cta={false}
>
  <section class="relative bg-white py-20 lg:py-28">
    <div class="mx-auto grid max-w-7xl items-start gap-12 px-5 lg:grid-cols-[1fr_1.05fr] lg:gap-16 lg:px-8">
      <!-- LEFT: contact details -->
      <div>
        <span class="reveal-up inline-flex items-center gap-2 font-heading text-[12px] font-bold uppercase tracking-[0.22em] text-brand-primary">
          <Motif class="h-3.5 w-3.5" variant="bolt" /> Get in touch
        </span>
        <h2 class="reveal-up mt-4 font-heading text-[clamp(1.9rem,4vw,2.8rem)] font-extrabold leading-[1.05] tracking-[-0.03em] text-brand-secondary">
          Talk to a local Engage electrician
        </h2>
        <p class="reveal-up mt-4 max-w-md font-body text-[1.05rem] leading-relaxed text-brand-muted">
          Residential, commercial or solar, we will sort it. Reach us however suits you best.
        </p>

        <!-- big call line -->
        <a href={site.phoneHref} class="reveal-scale group mt-8 flex w-fit items-center gap-4 rounded-2xl bg-brand-secondary px-6 py-4 shadow-xl transition-all hover:bg-brand-primary active:scale-95">
          <span class="grid h-12 w-12 place-items-center rounded-full bg-brand-accent text-brand-secondary transition group-hover:rotate-12">
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.6 10.8a15.5 15.5 0 0 0 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.2.4 2.4.6 3.7.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1A17 17 0 0 1 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.7.1.4 0 .7-.2 1l-2.3 2.1Z"/></svg>
          </span>
          <span class="text-left">
            <span class="block font-heading text-[11px] font-bold uppercase tracking-[0.18em] text-white/60">Call us direct</span>
            <span class="block font-heading text-[1.7rem] font-extrabold leading-none tracking-[-0.02em] text-white">{site.phone}</span>
          </span>
        </a>

        <!-- detail rows -->
        <dl class="reveal-up mt-8 space-y-5">
          <!-- NAP address — matches the Google Business Profile exactly (premises 488 Macauley St, entered via COD Lane) -->
          <div class="flex items-start gap-3.5">
            <span class="grid h-9 w-9 shrink-0 place-items-center rounded-lg bg-brand-primary/10 text-brand-primary">
              <svg class="h-4.5 w-4.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M12 21s7-5.5 7-11a7 7 0 1 0-14 0c0 5.5 7 11 7 11Z" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="10" r="2.5"/></svg>
            </span>
            <div>
              <dt class="font-heading text-[13px] font-bold uppercase tracking-[0.14em] text-brand-muted">Address</dt>
              <dd>
                <a href={site.address.mapsHref} target="_blank" rel="noopener" class="font-body text-[16px] font-semibold not-italic text-brand-secondary transition-colors hover:text-brand-primary">{site.address.full}</a>
              </dd>
            </div>
          </div>
          <div class="flex items-start gap-3.5">
            <span class="grid h-9 w-9 shrink-0 place-items-center rounded-lg bg-brand-primary/10 text-brand-primary">
              <svg class="h-4.5 w-4.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M4 6h16v12H4zM4 7l8 6 8-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            <div>
              <dt class="font-heading text-[13px] font-bold uppercase tracking-[0.14em] text-brand-muted">Email</dt>
              <dd><a href={`mailto:${site.email}`} class="font-body text-[16px] font-semibold text-brand-secondary transition-colors hover:text-brand-primary">{site.email}</a></dd>
            </div>
          </div>
          <div class="flex items-start gap-3.5">
            <span class="grid h-9 w-9 shrink-0 place-items-center rounded-lg bg-brand-primary/10 text-brand-primary">
              <Motif class="h-4 w-4" variant="bolt" />
            </span>
            <div>
              <dt class="font-heading text-[13px] font-bold uppercase tracking-[0.14em] text-brand-muted">Service area</dt>
              <dd class="font-body text-[16px] font-semibold text-brand-secondary">{site.footer.areas.join(' · ')}</dd>
            </div>
          </div>
          <div class="flex items-start gap-3.5">
            <span class="grid h-9 w-9 shrink-0 place-items-center rounded-lg bg-brand-primary/10 text-brand-primary">
              <svg class="h-4.5 w-4.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M12 7v5l3 2M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            <div>
              <dt class="font-heading text-[13px] font-bold uppercase tracking-[0.14em] text-brand-muted">Hours</dt>
              <dd class="font-body text-[16px] font-semibold text-brand-secondary">{site.footer.hours}</dd>
            </div>
          </div>
        </dl>

        <span class="reveal-up mt-7 inline-flex items-center gap-2 rounded-full bg-brand-surface px-4 py-2 font-body text-[13px] font-semibold text-brand-muted">
          <span class="h-2 w-2 rounded-full bg-green-500"></span> {site.footer.statusLine}
        </span>
      </div>

      <!-- RIGHT: callback form -->
      <div class="reveal-scale lg:sticky lg:top-28">
        {/*
          TODO (deferred — pending Jotform form ID from Craig):
          The full inline Jotform contact-form embed replaces or sits beside this
          CallbackForm once we have the form ID. Do NOT build a fake form in the
          meantime. When the ID lands, drop the Jotform <script>/iframe embed here.
          Until then, CallbackForm (the no-backend callback path) stands in.
        */}
        <CallbackForm site={site} id="contact-form" variant="hero" />
      </div>
    </div>
  </section>
</PageLayout>
