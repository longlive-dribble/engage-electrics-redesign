---
/*
  404.astro — branded "page not found" page.

  Built on the base Layout + the real site chrome (StickyHeader / Footer /
  MobileCallBar) rather than PageLayout, because a 404 has no breadcrumb trail
  and no closing FinalCTA — but it reuses PageLayout's charcoal page-hero band
  styling and the Motif so it reads as part of the brand, not a raw browser 404.

  Purpose: a missed redirect after the site migration must not dead-end a lead.
  It routes a lost visitor back to Home and Contact, and keeps the phone CTA live.

  Astro static output emits this file as /404.html, served on any unmatched route.
*/
import Layout from '../layouts/Layout.astro';
import StickyHeader from '../components/StickyHeader.astro';
import Footer from '../components/Footer.astro';
import MobileCallBar from '../components/MobileCallBar.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import Motif from '../components/Motif.astro';
import { site } from '../data/site.js';
---

<Layout
  title="Page not found | Engage Electrics · Albury Wodonga Electricians"
  description="That page could not be found. Head back home or get in touch with Engage Electrics, your local Albury-Wodonga electrician."
>
  <StickyHeader name={site.name} logo={site.logo} phone={site.phone} phoneHref={site.phoneHref} nav={site.nav} />

  <main>
    <!-- ===== 404 hero band (reuses PageLayout's charcoal + bolt motif) ===== -->
    <section class="relative flex min-h-[78vh] items-center overflow-hidden bg-brand-secondary pt-32 pb-20 lg:pt-40">
      <div class="pointer-events-none absolute inset-0">
        <div class="absolute inset-0 page-hero-grid opacity-[0.10]"></div>
        <div class="absolute -top-32 -right-24 h-[30rem] w-[30rem] rounded-full bg-brand-primary/25 blur-[120px]"></div>
        <Motif class="absolute -right-10 -top-6 h-[34rem] w-auto text-white/[0.03] float-slow" variant="bolt" />
      </div>

      <div class="relative mx-auto max-w-3xl px-5 text-center lg:px-8">
        <span class="reveal-down inline-flex items-center gap-2 font-heading text-[12px] font-bold uppercase tracking-[0.22em] text-brand-accent">
          <Motif class="h-3.5 w-3.5" variant="bolt" /> Error 404
        </span>

        <p class="reveal-down mt-5 font-heading text-[clamp(4rem,14vw,8rem)] font-extrabold leading-none tracking-[-0.04em] text-white" style="--d:80ms">
          404
        </p>

        <h1 class="reveal-down mt-2 font-heading text-[clamp(1.6rem,4vw,2.4rem)] font-extrabold leading-[1.1] tracking-[-0.02em] text-white" style="--d:140ms">
          We can&rsquo;t find that page
        </h1>

        <p class="reveal-down mx-auto mt-4 max-w-md font-body text-[clamp(1rem,2vw,1.15rem)] leading-relaxed text-white/75" style="--d:200ms">
          The link may be old or the page has moved. No worries &mdash; head back home, or get in touch and a local Engage electrician will sort you out.
        </p>

        <!-- exits: Home + Contact, plus the always-live phone CTA -->
        <div class="reveal-down mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row" style="--d:280ms">
          <a href="/" class="group inline-flex items-center justify-center gap-3 rounded-full bg-brand-accent px-6 py-3.5 font-heading text-[16px] font-extrabold tracking-tight text-brand-secondary shadow-xl shadow-brand-accent/20 transition-all hover:bg-white active:scale-95">
            <svg class="h-5 w-5 transition-transform group-hover:-translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true"><path d="M3 11.5 12 4l9 7.5M5 10v9a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-9" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Back to home
          </a>
          <a href="/contact" class="inline-flex items-center justify-center gap-2 rounded-full border border-white/20 px-6 py-3.5 font-heading text-[15px] font-bold text-white transition-all hover:border-white/50 hover:bg-white/5">
            Contact us
          </a>
        </div>

        <!-- direct call line, in case the visitor would rather just ring -->
        <a href={site.phoneHref} class="reveal-down mt-7 inline-flex items-center gap-2 font-heading text-[15px] font-bold text-white/80 transition-colors hover:text-brand-accent" style="--d:340ms">
          <svg class="h-4.5 w-4.5 text-brand-primary" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.6 10.8a15.5 15.5 0 0 0 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.2.4 2.4.6 3.7.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1A17 17 0 0 1 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.7.1.4 0 .7-.2 1l-2.3 2.1Z"/></svg>
          Or call {site.phone}
        </a>
      </div>
    </section>
  </main>

  <Footer site={site} />
  <MobileCallBar site={site} />
  <ScrollReveal />
</Layout>

<style>
  @reference "../styles/global.css";
  .page-hero-grid {
    background-image:
      linear-gradient(rgba(255,255,255,0.4) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.4) 1px, transparent 1px);
    background-size: 42px 42px;
    mask-image: radial-gradient(ellipse 90% 70% at 50% 35%, #000 40%, transparent 100%);
  }
</style>
