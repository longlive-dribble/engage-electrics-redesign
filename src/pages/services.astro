---
import PageLayout from '../layouts/PageLayout.astro';
import Motif from '../components/Motif.astro';
import ServiceIcon from '../components/ServiceIcon.astro';
import { site } from '../data/site.js';
---

<PageLayout
  title="Services | Engage Electrics · Residential, Commercial & Solar"
  description="Residential, commercial, solar and re-wiring across Albury-Wodonga, NE Victoria and Southern NSW. One local, award-winning team."
  heading="Everything electrical, one local team"
  sub="Residential, commercial, solar and re-wiring across Albury-Wodonga and the surrounding regions. Done correctly and safely the first time."
  crumb="Services"
>
  <!-- ===== Detailed service breakdown ===== -->
  <section class="relative bg-white py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <div class="space-y-5">
        {site.servicesDetail.map((s, i) => (
          <article
            class="reveal-up grid gap-8 overflow-hidden rounded-3xl border border-brand-secondary/8 bg-brand-surface p-7 lg:grid-cols-[0.85fr_1.15fr] lg:gap-12 lg:p-10"
            style={`--d:${(i % 2) * 80}ms`}
          >
            <!-- left: branded panel -->
            <div class:list={["relative flex flex-col justify-between overflow-hidden rounded-2xl bg-brand-secondary p-7", i % 2 === 1 && "lg:order-2"]}>
              <Motif class="pointer-events-none absolute -right-6 -top-4 h-40 w-auto text-white/[0.05]" variant="bolt" />
              <div>
                <span class="grid h-14 w-14 place-items-center rounded-2xl bg-brand-primary text-white shadow-lg shadow-brand-primary/30" style="--bolt:#3C4140">
                  <ServiceIcon class="h-7 w-7" name={s.icon} />
                </span>
                <h2 class="mt-6 font-heading text-[clamp(1.6rem,3vw,2.2rem)] font-extrabold leading-[1.05] tracking-[-0.025em] text-white">{s.title}</h2>
                <p class="mt-3 font-body text-[1.02rem] leading-relaxed text-brand-accent">{s.tagline}</p>
              </div>
              <a href={site.phoneHref} class="mt-7 inline-flex w-fit items-center gap-2.5 rounded-full bg-white px-5 py-3 font-heading text-[14px] font-extrabold text-brand-secondary transition-all hover:bg-brand-accent active:scale-95">
                <svg class="h-4 w-4 text-brand-primary" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.6 10.8a15.5 15.5 0 0 0 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.2.4 2.4.6 3.7.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1A17 17 0 0 1 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.7.1.4 0 .7-.2 1l-2.3 2.1Z"/></svg>
                Enquire about {s.title.split(' ')[0].toLowerCase()}
              </a>
            </div>

            <!-- right: detail -->
            <div class="flex flex-col justify-center">
              <p class="font-body text-[1.08rem] leading-relaxed text-brand-text">{s.body}</p>
              <ul class="mt-6 grid gap-3 sm:grid-cols-2">
                {s.bullets.map((b) => (
                  <li class="flex items-start gap-3 font-body text-[15px] text-brand-muted">
                    <span class="mt-0.5 grid h-5 w-5 shrink-0 place-items-center rounded-full bg-brand-primary/10 text-brand-primary">
                      <svg class="h-3 w-3" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M9.5 17.6 4.4 12.5l1.6-1.6 3.5 3.5 8.5-8.5 1.6 1.6-10.1 10.1Z"/></svg>
                    </span>
                    {b}
                  </li>
                ))}
              </ul>
            </div>
          </article>
        ))}
      </div>

      <p class="reveal-up mt-10 text-center font-body text-[15px] text-brand-muted">
        Not listed? We probably do it. <a href={site.phoneHref} class="font-bold text-brand-primary underline-offset-2 hover:underline">Just ask on {site.phone}</a>
      </p>
    </div>
  </section>
</PageLayout>
