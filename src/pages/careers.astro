---
import PageLayout from '../layouts/PageLayout.astro';
import Motif from '../components/Motif.astro';
import { site } from '../data/site.js';
const c = site.careers;
---

<PageLayout
  title="Careers | Engage Electrics · Join the Border's Award-winning Team"
  description="Join Engage Electrics. We are an award-winning, local Albury-Wodonga team always keen to hear from good electricians, apprentices and solar installers."
  heading="Join the Engage team"
  sub="An award-winning local team, real variety of work, and a crew that has your back."
  crumb="Careers"
  cta={false}
>
  <!-- intro + why work here -->
  <section class="relative bg-white py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-[0.85fr_1.15fr] lg:gap-16">
        <div class="lg:sticky lg:top-28 lg:self-start">
          <span class="reveal-up inline-flex items-center gap-2 font-heading text-[12px] font-bold uppercase tracking-[0.22em] text-brand-primary">
            <Motif class="h-3.5 w-3.5" variant="bolt" /> Work with us
          </span>
          <h2 class="reveal-up mt-4 font-heading text-[clamp(1.9rem,4vw,2.8rem)] font-extrabold leading-[1.05] tracking-[-0.03em] text-brand-secondary">{c.heading}</h2>
          <p class="reveal-up mt-5 max-w-md font-body text-[1.08rem] leading-relaxed text-brand-muted">{c.intro}</p>
        </div>

        <div class="grid gap-3.5 sm:grid-cols-2">
          {c.why.map((w, i) => (
            <div class="reveal-left flex items-start gap-3.5 rounded-2xl border border-brand-secondary/8 bg-brand-surface p-5 transition-colors hover:border-brand-primary/25" style={`--d:${i * 60}ms`}>
              <span class="grid h-9 w-9 shrink-0 place-items-center rounded-lg bg-brand-primary text-white">
                <Motif class="h-4 w-4" variant="bolt" />
              </span>
              <div>
                <p class="font-heading text-[16px] font-extrabold leading-tight tracking-[-0.01em] text-brand-secondary">{w.title}</p>
                <p class="mt-1 font-body text-[13.5px] leading-snug text-brand-muted">{w.sub}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- open roles -->
  <section class="relative bg-brand-surface py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <span class="reveal-up inline-flex items-center gap-2 font-heading text-[12px] font-bold uppercase tracking-[0.22em] text-brand-primary">
          <Motif class="h-3.5 w-3.5" variant="bolt" /> Roles
        </span>
        <h2 class="reveal-up mt-4 font-heading text-[clamp(1.8rem,4vw,2.6rem)] font-extrabold leading-[1.05] tracking-[-0.03em] text-brand-secondary">Who we would love to hear from</h2>
      </div>

      <div class="mt-12 grid gap-5 lg:grid-cols-3">
        {c.roles.map((r, i) => (
          <article class="reveal-up flex flex-col rounded-2xl border border-brand-secondary/8 bg-white p-7 shadow-sm transition-all duration-300 hover:-translate-y-1.5 hover:shadow-2xl hover:shadow-brand-secondary/10" style={`--d:${i * 70}ms`}>
            <span class="w-fit rounded-full bg-brand-primary/10 px-3 py-1 font-heading text-[11px] font-bold uppercase tracking-[0.12em] text-brand-primary">{r.type}</span>
            <h3 class="mt-4 font-heading text-[20px] font-extrabold leading-tight tracking-[-0.01em] text-brand-secondary">{r.title}</h3>
            <p class="mt-2.5 flex-1 font-body text-[14.5px] leading-relaxed text-brand-muted">{r.blurb}</p>
            <a href={`mailto:${site.email}?subject=${encodeURIComponent('Careers enquiry: ' + r.title)}`} class="mt-6 inline-flex items-center gap-2 font-heading text-[14px] font-bold text-brand-primary hover:underline">
              Apply for this role
              <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14m-6-6 6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </article>
        ))}
      </div>

      <!-- apply CTA -->
      <div class="reveal-up mx-auto mt-14 max-w-3xl rounded-3xl bg-brand-secondary p-9 text-center shadow-xl lg:p-12">
        <h3 class="font-heading text-[clamp(1.5rem,3vw,2.1rem)] font-extrabold leading-tight tracking-[-0.02em] text-white">Not listed but keen anyway?</h3>
        <p class="mx-auto mt-3 max-w-xl font-body text-[1.05rem] leading-relaxed text-white/75">{c.applyLine}</p>
        <div class="mt-7 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <a href={`mailto:${site.email}?subject=${encodeURIComponent('Careers enquiry')}`} class="inline-flex items-center justify-center gap-2.5 rounded-full bg-brand-accent px-6 py-3.5 font-heading text-[16px] font-extrabold tracking-tight text-brand-secondary transition-all hover:bg-white active:scale-95">
            Email us your details
          </a>
          <a href={site.phoneHref} class="inline-flex items-center justify-center gap-2.5 rounded-full border border-white/20 px-6 py-3.5 font-heading text-[15px] font-bold text-white transition-all hover:border-white/50 hover:bg-white/5">
            Or call {site.phone}
          </a>
        </div>
        <p class="mt-6 font-body text-[12px] text-white/40">{c.note}</p>
      </div>
    </div>
  </section>
</PageLayout>
