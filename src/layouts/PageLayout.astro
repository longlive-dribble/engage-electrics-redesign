---
/*
  PageLayout.astro — REUSABLE INTERIOR PAGE TEMPLATE.

  Every non-home page (Services, About, Contact, and any future page) is built on
  this. It supplies the full chrome — sticky header, a branded page-hero band,
  the closing call-to-action, footer and mobile call bar — so a new page is just:

      <PageLayout title="..." heading="..." sub="..." crumb="...">
        ...your page sections here...
      </PageLayout>

  Props:
    title       — <title> / SEO title
    description — meta description
    eyebrow     — small label above the heading (defaults to the brand area)
    heading     — the big H1 in the page-hero band
    sub         — supporting line under the heading
    crumb       — current page label for the breadcrumb (Home / {crumb})
    cta         — show the closing FinalCTA section (default true; off for Contact)
*/
import Layout from './Layout.astro';
import StickyHeader from '../components/StickyHeader.astro';
import Footer from '../components/Footer.astro';
import MobileCallBar from '../components/MobileCallBar.astro';
import FinalCTA from '../components/FinalCTA.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import Motif from '../components/Motif.astro';
import { site } from '../data/site.js';

interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
  heading: string;
  sub?: string;
  crumb: string;
  cta?: boolean;
}
const {
  title,
  description = site.hero.subhead,
  eyebrow = `Engage Electrics · ${site.area}`,
  heading,
  sub = '',
  crumb,
  cta = true,
} = Astro.props;
---

<Layout title={title} description={description}>
  <StickyHeader name={site.name} logo={site.logo} phone={site.phone} phoneHref={site.phoneHref} nav={site.nav} />

  <main>
    <!-- ===== Page-hero band (matches the home hero's charcoal + bolt motif) ===== -->
    <section class="relative overflow-hidden bg-brand-secondary pt-32 pb-16 lg:pt-40 lg:pb-20">
      <div class="pointer-events-none absolute inset-0">
        <div class="absolute inset-0 page-hero-grid opacity-[0.10]"></div>
        <div class="absolute -top-32 -right-24 h-[30rem] w-[30rem] rounded-full bg-brand-primary/25 blur-[120px]"></div>
        <Motif class="absolute -right-10 -top-6 h-[34rem] w-auto text-white/[0.03] float-slow" variant="bolt" />
      </div>

      <div class="relative mx-auto max-w-7xl px-5 lg:px-8">
        <!-- breadcrumb -->
        <nav class="reveal-down flex items-center gap-2 font-body text-[13px] font-semibold text-white/55" aria-label="Breadcrumb">
          <a href="/" class="transition-colors hover:text-white">Home</a>
          <svg class="h-3.5 w-3.5 text-white/30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="m9 6 6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <span class="text-brand-accent">{crumb}</span>
        </nav>

        <span class="reveal-down mt-6 inline-flex items-center gap-2 font-heading text-[12px] font-bold uppercase tracking-[0.22em] text-brand-accent" style="--d:60ms">
          <Motif class="h-3.5 w-3.5" variant="bolt" /> {eyebrow}
        </span>
        <h1 class="reveal-down mt-4 max-w-3xl font-heading text-[clamp(2.4rem,5.5vw,4rem)] font-extrabold leading-[1] tracking-[-0.035em] text-white" style="--d:120ms">
          {heading}
        </h1>
        {sub && (
          <p class="reveal-down mt-5 max-w-2xl font-body text-[clamp(1.05rem,2vw,1.2rem)] leading-relaxed text-white/75" style="--d:200ms">
            {sub}
          </p>
        )}

        <!-- quick CTA row -->
        <div class="reveal-down mt-8 flex flex-col gap-3 sm:flex-row sm:items-center" style="--d:280ms">
          <a href={site.phoneHref} class="group inline-flex items-center justify-center gap-3 rounded-full bg-brand-accent px-6 py-3.5 font-heading text-[16px] font-extrabold tracking-tight text-brand-secondary shadow-xl shadow-brand-accent/20 transition-all hover:bg-white active:scale-95">
            <svg class="h-5 w-5 transition-transform group-hover:rotate-12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.6 10.8a15.5 15.5 0 0 0 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.2.4 2.4.6 3.7.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1A17 17 0 0 1 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.7.1.4 0 .7-.2 1l-2.3 2.1Z"/></svg>
            Call {site.phone}
          </a>
          <a href="/contact" class="inline-flex items-center justify-center gap-2 rounded-full border border-white/20 px-6 py-3.5 font-heading text-[15px] font-bold text-white transition-all hover:border-white/50 hover:bg-white/5">
            Request a callback
          </a>
        </div>
      </div>
    </section>

    <!-- ===== Page body ===== -->
    <slot />

    {cta && <FinalCTA site={site} />}
  </main>

  <Footer site={site} />
  <MobileCallBar site={site} />
  <ScrollReveal />
</Layout>

<style>
  @reference "../styles/global.css";
  .page-hero-grid {
    background-image:
      linear-gradient(rgba(255,255,255,0.4) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.4) 1px, transparent 1px);
    background-size: 42px 42px;
    mask-image: radial-gradient(ellipse 90% 70% at 50% 35%, #000 40%, transparent 100%);
  }
</style>
