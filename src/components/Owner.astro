---
/*
  Owner.astro — visible founder block (the reference HID its owner).
  "Meet [Owner]" + personal story + years + branded photo slot + signature.
  Inverted navy section for rhythm; overlap between photo + a floating stat.
*/
import Motif from './Motif.astro';
interface Props {
  site: any;
}
const { site } = Astro.props;
const o = site.owner;
---
<section id="about" class="relative overflow-hidden bg-brand-secondary py-20 lg:py-28">
  <div class="pointer-events-none absolute inset-0 owner-grid opacity-[0.08]"></div>
  <Motif class="pointer-events-none absolute -left-10 top-1/2 h-[30rem] w-auto -translate-y-1/2 text-white/[0.03]" variant="bolt" />

  <div class="relative mx-auto grid max-w-7xl items-center gap-12 px-5 lg:grid-cols-[0.9fr_1.1fr] lg:gap-16 lg:px-8">
    <!-- branded photo slot -->
    <div class="reveal-scale relative mx-auto w-full max-w-sm lg:mx-0">
      <div class="relative aspect-[4/5] overflow-hidden rounded-[1.6rem] border border-white/10 shadow-2xl">
        <img src="/img/team.jpg" alt="Engage Electrics team on the job in Albury-Wodonga" class="absolute inset-0 h-full w-full object-cover" style="object-position:center 30%" />
        <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/60 to-transparent p-6">
          <span class="inline-flex items-center gap-2 rounded-full bg-black/40 px-3 py-1.5 backdrop-blur">
            <span class="h-1.5 w-1.5 rounded-full bg-brand-accent"></span>
            <span class="font-body text-[12px] italic text-white/85">Engage Electrics, Albury-Wodonga</span>
          </span>
        </div>
      </div>
      <!-- overlapping floating award badge -->
      <div class="absolute -bottom-6 -right-4 rotate-[-4deg] rounded-2xl bg-brand-accent px-5 py-3.5 text-center shadow-xl">
        <p class="font-heading text-[2rem] font-extrabold leading-none tracking-[-0.04em] text-brand-secondary">2025</p>
        <p class="font-heading text-[10px] font-bold uppercase tracking-[0.14em] text-brand-secondary/80">award winner</p>
      </div>
    </div>

    <!-- story -->
    <div>
      <span class="reveal-up inline-flex items-center gap-2 font-heading text-[12px] font-bold uppercase tracking-[0.22em] text-brand-accent">
        <Motif class="h-3.5 w-3.5" variant="bolt" /> Local to The Border
      </span>
      <h2 class="reveal-up mt-4 font-heading text-[clamp(2rem,4.5vw,3.2rem)] font-extrabold leading-[1.02] tracking-[-0.03em] text-white">
        {o.heading}
      </h2>
      <div class="reveal-up mt-6 space-y-4 font-body text-[1.08rem] leading-relaxed text-white/75">
        {o.story.map((p: string) => <p>{p}</p>)}
      </div>

      <!-- signature + reachability -->
      <div class="reveal-up mt-8 flex flex-wrap items-center gap-6">
        <div>
          <p class="font-heading text-[1.6rem] italic leading-none text-brand-accent" style="font-weight:600">{o.signature}</p>
          <p class="mt-1.5 font-body text-[13px] text-white/55">{o.name}, {o.role}</p>
        </div>
        <a href={site.phoneHref} class="inline-flex items-center gap-2.5 rounded-full bg-white px-5 py-3 font-heading text-[14px] font-extrabold text-brand-secondary transition-all hover:bg-brand-accent active:scale-95">
          <svg class="h-4 w-4 text-brand-primary" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.6 10.8a15.5 15.5 0 0 0 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.2.4 2.4.6 3.7.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1A17 17 0 0 1 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.7.1.4 0 .7-.2 1l-2.3 2.1Z"/></svg>
          {o.ctaLabel}
        </a>
      </div>
    </div>
  </div>

  <style>
    @reference "../styles/global.css";
    .owner-grid {
      background-image:
        linear-gradient(rgba(255,255,255,0.4) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.4) 1px, transparent 1px);
      background-size: 44px 44px;
    }
  </style>
</section>
