---
/*
  CallBanner.astro — inverted (brand-primary) urgency banner.
  A relentless mid-page conversion shove toward the phone.
  Non-straight top edge (clip-path slant) for layout tension.
*/
import Motif from './Motif.astro';
interface Props {
  site: any;
}
const { site } = Astro.props;
---
<section class="relative overflow-hidden bg-brand-primary py-16 lg:py-20 banner-slant">
  <!-- texture + motif depth -->
  <div class="pointer-events-none absolute inset-0 banner-grid opacity-[0.12]"></div>
  <Motif class="pointer-events-none absolute -right-8 -top-6 h-[26rem] w-auto text-white/[0.06] float-slow" variant="bolt" />
  <Motif class="pointer-events-none absolute bottom-0 left-10 h-40 w-auto text-brand-secondary/10" variant="bolt" />

  <div class="relative mx-auto flex max-w-7xl flex-col items-center gap-8 px-5 text-center lg:flex-row lg:justify-between lg:text-left lg:px-8">
    <div>
      <span class="reveal-up inline-flex items-center gap-2 rounded-full bg-brand-secondary/30 px-3.5 py-1.5 font-heading text-[11px] font-bold uppercase tracking-[0.18em] text-white">
        <span class="relative flex h-2 w-2"><span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-brand-accent opacity-75"></span><span class="relative inline-flex h-2 w-2 rounded-full bg-brand-accent"></span></span>
        {site.banner.eyebrow}
      </span>
      <h2 class="reveal-up mt-4 max-w-2xl font-heading text-[clamp(1.9rem,4.5vw,3rem)] font-extrabold leading-[1.03] tracking-[-0.03em] text-white">
        {site.banner.heading}
      </h2>
      <p class="reveal-up mt-3 max-w-xl font-body text-[1.05rem] text-white/85">{site.banner.sub}</p>
    </div>

    <a
      href={site.phoneHref}
      class="reveal-scale group inline-flex shrink-0 flex-col items-center gap-1 rounded-2xl bg-white px-9 py-5 shadow-2xl transition-all hover:bg-brand-accent active:scale-95"
    >
      <span class="font-heading text-[11px] font-bold uppercase tracking-[0.2em] text-brand-primary transition-colors group-hover:text-brand-secondary">Tap to call now</span>
      <span class="flex items-center gap-2.5 font-heading text-[clamp(1.5rem,3vw,2rem)] font-extrabold tracking-[-0.02em] text-brand-secondary">
        <svg class="h-6 w-6 text-brand-primary transition-transform group-hover:rotate-12 group-hover:text-brand-secondary" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.6 10.8a15.5 15.5 0 0 0 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.2.4 2.4.6 3.7.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1A17 17 0 0 1 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.7.1.4 0 .7-.2 1l-2.3 2.1Z"/></svg>
        {site.phone}
      </span>
    </a>
  </div>
</section>

<style>
  @reference "../styles/global.css";
  .banner-slant {
    clip-path: polygon(0 2.2rem, 100% 0, 100% 100%, 0 100%);
  }
  .banner-grid {
    background-image:
      linear-gradient(rgba(255,255,255,0.5) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.5) 1px, transparent 1px);
    background-size: 40px 40px;
  }
</style>
