---
/*
  ScrollReveal.astro — one IntersectionObserver that drives every .reveal-* element.
  Adds .is-visible when an element scrolls into view, triggering the staggered
  entrance defined in base.css. Elements above the fold reveal immediately.
*/
---
<script is:inline>
  (function () {
    const sel = '.reveal-up, .reveal-down, .reveal-left, .reveal-scale';
    const els = Array.from(document.querySelectorAll(sel));
    if (!els.length) return;

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce) {
      els.forEach((el) => el.classList.add('is-visible'));
      return;
    }

    // reveal anything already in view on load (hero) right away
    const vh = window.innerHeight;
    els.forEach((el) => {
      const top = el.getBoundingClientRect().top;
      if (top < vh * 0.9) el.classList.add('is-visible');
    });

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
    );
    els.forEach((el) => {
      if (!el.classList.contains('is-visible')) io.observe(el);
    });
  })();
</script>
