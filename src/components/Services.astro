---
/*
  Services.astro — 8-card service grid. Each card: inline SVG icon + title + 1-liner.
  Icons are keyed by service.icon; bolt motif sits in the section eyebrow + on hover.
*/
import Motif from './Motif.astro';
import ServiceIcon from './ServiceIcon.astro';
interface Props {
  site: any;
}
const { site } = Astro.props;
---
<section id="services" class="relative overflow-hidden bg-brand-surface py-20 lg:py-28">
  <Motif class="pointer-events-none absolute -left-16 top-24 h-72 w-auto text-brand-primary/[0.04]" variant="bolt" />
  <div class="relative mx-auto max-w-7xl px-5 lg:px-8">
    <!-- header -->
    <div class="mx-auto max-w-2xl text-center">
      <span class="reveal-up inline-flex items-center gap-2 font-heading text-[12px] font-bold uppercase tracking-[0.22em] text-brand-primary">
        <Motif class="h-3.5 w-3.5" variant="bolt" /> What we do
      </span>
      <h2 class="reveal-up mt-4 font-heading text-[clamp(2rem,4.5vw,3.2rem)] font-extrabold leading-[1.02] tracking-[-0.03em] text-brand-secondary">
        {site.servicesHeading}
      </h2>
      <p class="reveal-up mx-auto mt-4 max-w-xl font-body text-[1.05rem] text-brand-muted">{site.servicesSub}</p>
    </div>

    <!-- grid -->
    <div class="mt-14 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {site.services.map((s: any, i: number) => (
        <div
          class="reveal-up group relative overflow-hidden rounded-2xl border border-brand-secondary/8 bg-white p-6 transition-all duration-300 hover:-translate-y-1.5 hover:border-brand-primary/30 hover:shadow-2xl hover:shadow-brand-secondary/10"
          style={`--d:${(i % 4) * 60}ms`}
        >
          <!-- hover accent corner -->
          <Motif class="absolute -right-3 -top-3 h-16 w-auto text-brand-accent/0 transition-all duration-300 group-hover:text-brand-accent/15" variant="bolt" />
          <span class="grid h-12 w-12 place-items-center rounded-xl bg-brand-primary/10 text-brand-secondary transition-all duration-300 [--bolt:#F47D30] group-hover:bg-brand-primary group-hover:text-white group-hover:[--bolt:#3C4140]">
            <ServiceIcon class="h-6 w-6" name={s.icon} />
          </span>
          <h3 class="mt-5 font-heading text-[18px] font-extrabold leading-tight tracking-[-0.01em] text-brand-secondary">{s.title}</h3>
          <p class="mt-2 font-body text-[14px] leading-relaxed text-brand-muted">{s.desc}</p>
          <a href={site.phoneHref} class="mt-4 inline-flex items-center gap-1.5 font-heading text-[13px] font-bold text-brand-primary opacity-0 transition-all duration-300 group-hover:opacity-100">
            Book this
            <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14m-6-6 6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      ))}
    </div>

    <p class="reveal-up mt-10 text-center font-body text-[15px] text-brand-muted">
      Not listed? We probably do it. <a href={site.phoneHref} class="font-bold text-brand-primary underline-offset-2 hover:underline">Just ask on {site.phone}</a>
    </p>
  </div>
</section>
