---
/*
  Reviews.astro — THE flagged must-have. A populated, auto-scrolling Google-style
  reviews marquee. Cards are duplicated once so the CSS-animated track loops
  seamlessly; animation PAUSES on hover (and respects prefers-reduced-motion).
  Each card: gold star row + quote + reviewer name + suburb + Google mark.
  Two rows scrolling opposite directions for richness.
*/
import Motif from './Motif.astro';
interface Props {
  site: any;
}
const { site } = Astro.props;

const reviews = site.reviews;
const mid = Math.ceil(reviews.length / 2);
const rowA = reviews.slice(0, mid);
const rowB = reviews.slice(mid).concat(reviews.slice(0, Math.max(0, mid - (reviews.length - mid))));

const GoogleMark = `<svg viewBox="0 0 24 24" class="h-4 w-4" aria-hidden="true"><path fill="#4285F4" d="M23 12.3c0-.8-.1-1.6-.2-2.3H12v4.5h6.2a5.3 5.3 0 0 1-2.3 3.5v2.9h3.7C21.7 18.9 23 15.9 23 12.3Z"/><path fill="#34A853" d="M12 24c3.1 0 5.7-1 7.6-2.8l-3.7-2.9c-1 .7-2.3 1.1-3.9 1.1-3 0-5.5-2-6.4-4.8H1.8v3C3.7 21.3 7.5 24 12 24Z"/><path fill="#FBBC05" d="M5.6 14.6a7.2 7.2 0 0 1 0-4.6v-3H1.8a12 12 0 0 0 0 10.6l3.8-3Z"/><path fill="#EA4335" d="M12 4.8c1.7 0 3.2.6 4.4 1.7l3.3-3.3C17.7 1.2 15.1 0 12 0 7.5 0 3.7 2.7 1.8 6.6l3.8 3C6.5 6.8 9 4.8 12 4.8Z"/></svg>`;
---
<section id="reviews" class="relative overflow-hidden bg-brand-surface py-20 lg:py-28">
  <Motif class="pointer-events-none absolute -right-16 bottom-12 h-72 w-auto text-brand-primary/[0.04]" variant="bolt" />

  <div class="relative mx-auto max-w-7xl px-5 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <span class="reveal-up inline-flex items-center gap-2 font-heading text-[12px] font-bold uppercase tracking-[0.22em] text-brand-primary">
        <Motif class="h-3.5 w-3.5" variant="bolt" /> Testimonials
      </span>
      <h2 class="reveal-up mt-4 font-heading text-[clamp(2rem,4.5vw,3.2rem)] font-extrabold leading-[1.02] tracking-[-0.03em] text-brand-secondary">
        {site.reviewsHeading}
      </h2>
      <!-- reviews placeholder note (live Google reviews wire in here) -->
      <div class="reveal-up mt-5 inline-flex items-center gap-2.5 rounded-full border border-brand-secondary/8 bg-white px-5 py-2.5 shadow-sm">
        <Fragment set:html={GoogleMark} />
        <span class="font-body text-[13.5px] text-brand-muted">Your live Google reviews appear here</span>
      </div>
    </div>
  </div>

  <!-- MARQUEE rows (full-bleed) -->
  <div class="reveal-up relative mt-14">
    <!-- edge fades -->
    <div class="pointer-events-none absolute inset-y-0 left-0 z-10 w-16 bg-gradient-to-r from-brand-surface to-transparent sm:w-32"></div>
    <div class="pointer-events-none absolute inset-y-0 right-0 z-10 w-16 bg-gradient-to-l from-brand-surface to-transparent sm:w-32"></div>

    <div class="marquee group flex gap-4 py-2">
      <div class="marquee-track flex shrink-0 gap-4">
        {rowA.concat(rowA).map((r: any) => (
          <article class="flex w-[300px] shrink-0 flex-col rounded-2xl border border-brand-secondary/8 bg-white p-6 shadow-sm sm:w-[340px]">
            <div class="flex items-center justify-between">
              <span class="flex items-center gap-0.5 text-brand-accent">
                {[...Array(5)].map(() => (<svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="m10 1 2.6 5.3 5.8.8-4.2 4.1 1 5.8L10 14.8 4.8 17l1-5.8L1.6 7.1l5.8-.8L10 1Z"/></svg>))}
              </span>
              <Fragment set:html={GoogleMark} />
            </div>
            <p class="mt-4 flex-1 font-body text-[14.5px] leading-relaxed text-brand-text">“{r.quote}”</p>
            <div class="mt-5 flex items-center gap-3 border-t border-brand-secondary/8 pt-4">
              <span class="grid h-9 w-9 place-items-center rounded-full bg-brand-primary/10 font-heading text-[14px] font-extrabold text-brand-primary">{r.name.charAt(0)}</span>
              <div>
                <p class="font-heading text-[14px] font-bold text-brand-secondary">{r.name}</p>
                <p class="font-body text-[12.5px] text-brand-muted">{r.suburb}</p>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>

    <div class="marquee group mt-4 flex gap-4 py-2">
      <div class="marquee-track marquee-reverse flex shrink-0 gap-4">
        {rowB.concat(rowB).map((r: any) => (
          <article class="flex w-[300px] shrink-0 flex-col rounded-2xl border border-brand-secondary/8 bg-white p-6 shadow-sm sm:w-[340px]">
            <div class="flex items-center justify-between">
              <span class="flex items-center gap-0.5 text-brand-accent">
                {[...Array(5)].map(() => (<svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="m10 1 2.6 5.3 5.8.8-4.2 4.1 1 5.8L10 14.8 4.8 17l1-5.8L1.6 7.1l5.8-.8L10 1Z"/></svg>))}
              </span>
              <Fragment set:html={GoogleMark} />
            </div>
            <p class="mt-4 flex-1 font-body text-[14.5px] leading-relaxed text-brand-text">“{r.quote}”</p>
            <div class="mt-5 flex items-center gap-3 border-t border-brand-secondary/8 pt-4">
              <span class="grid h-9 w-9 place-items-center rounded-full bg-brand-primary/10 font-heading text-[14px] font-extrabold text-brand-primary">{r.name.charAt(0)}</span>
              <div>
                <p class="font-heading text-[14px] font-bold text-brand-secondary">{r.name}</p>
                <p class="font-body text-[12.5px] text-brand-muted">{r.suburb}</p>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>

  <div class="relative mt-12 text-center">
    <a href={site.phoneHref} class="reveal-up inline-flex items-center gap-2.5 rounded-full bg-brand-primary px-7 py-4 font-heading text-[16px] font-extrabold tracking-tight text-white shadow-lg shadow-brand-primary/25 transition-all hover:bg-brand-secondary active:scale-95">
      Talk to the Engage team today. Call {site.phone}
    </a>
  </div>

  <style>
    .marquee { overflow: hidden; }
    .marquee-track {
      width: max-content;
      animation: marquee-scroll 46s linear infinite;
    }
    .marquee-reverse { animation-direction: reverse; }
    /* pause on hover — the flagged requirement */
    .marquee:hover .marquee-track { animation-play-state: paused; }
    @keyframes marquee-scroll {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }
    @media (prefers-reduced-motion: reduce) {
      .marquee-track { animation: none; }
    }
  </style>
</section>
