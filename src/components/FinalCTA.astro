---
/*
  FinalCTA.astro — closing conversion section: relentless call CTA + the second
  callback form instance. Inverted navy with bolt motif texture.
*/
import Motif from './Motif.astro';
import CallbackForm from './CallbackForm.astro';
interface Props {
  site: any;
}
const { site } = Astro.props;
---
<section id="contact" class="relative overflow-hidden bg-brand-secondary py-20 lg:py-28">
  <div class="pointer-events-none absolute inset-0 cta-grid opacity-[0.08]"></div>
  <div class="pointer-events-none absolute -top-24 left-1/2 h-[30rem] w-[30rem] -translate-x-1/2 rounded-full bg-brand-primary/20 blur-[120px]"></div>
  <Motif class="pointer-events-none absolute bottom-0 right-8 h-72 w-auto text-white/[0.04] float-slow" variant="bolt" />

  <div class="relative mx-auto grid max-w-7xl items-center gap-12 px-5 lg:grid-cols-2 lg:gap-16 lg:px-8">
    <!-- pitch -->
    <div>
      <span class="reveal-up inline-flex items-center gap-2 font-heading text-[12px] font-bold uppercase tracking-[0.22em] text-brand-accent">
        <Motif class="h-3.5 w-3.5" variant="bolt" /> {site.finalCTA.eyebrow}
      </span>
      <h2 class="reveal-up mt-4 font-heading text-[clamp(2.1rem,5vw,3.6rem)] font-extrabold leading-[1] tracking-[-0.035em] text-white">
        {site.finalCTA.heading}
      </h2>
      <p class="reveal-up mt-5 max-w-md font-body text-[1.1rem] leading-relaxed text-white/75">{site.finalCTA.sub}</p>

      <!-- big call line -->
      <a href={site.phoneHref} class="reveal-scale group mt-8 inline-flex items-center gap-4 rounded-2xl bg-brand-accent px-7 py-5 shadow-2xl shadow-brand-accent/20 transition-all hover:bg-white active:scale-95">
        <span class="grid h-12 w-12 place-items-center rounded-full bg-brand-secondary text-white transition group-hover:rotate-12">
          <svg class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.6 10.8a15.5 15.5 0 0 0 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.2.4 2.4.6 3.7.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1A17 17 0 0 1 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.7.1.4 0 .7-.2 1l-2.3 2.1Z"/></svg>
        </span>
        <span class="text-left">
          <span class="block font-heading text-[11px] font-bold uppercase tracking-[0.18em] text-brand-secondary/70">Call us direct</span>
          <span class="block font-heading text-[clamp(1.5rem,3vw,2rem)] font-extrabold leading-none tracking-[-0.02em] text-brand-secondary">{site.phone}</span>
        </span>
      </a>

      <ul class="reveal-up mt-8 space-y-2.5">
        {site.finalCTA.points.map((p: string) => (
          <li class="flex items-center gap-3 font-body text-[15px] text-white/80">
            <span class="grid h-5 w-5 shrink-0 place-items-center rounded-full bg-brand-accent/20 text-brand-accent">
              <svg class="h-3 w-3" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M9.5 17.6 4.4 12.5l1.6-1.6 3.5 3.5 8.5-8.5 1.6 1.6-10.1 10.1Z"/></svg>
            </span>
            {p}
          </li>
        ))}
      </ul>
    </div>

    <!-- callback form (secondary path, repeated) -->
    <div class="reveal-scale">
      <CallbackForm site={site} id="callback-form-final" variant="panel" />
    </div>
  </div>

  <style>
    @reference "../styles/global.css";
    .cta-grid {
      background-image:
        linear-gradient(rgba(255,255,255,0.4) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.4) 1px, transparent 1px);
      background-size: 44px 44px;
      mask-image: radial-gradient(ellipse 80% 80% at 30% 40%, #000 30%, transparent 100%);
    }
  </style>
</section>
